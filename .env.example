# Systems Design Lab — environment.
# Copy to .env (`cp .env.example .env`). All tunables documented inline.

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# Replication role used by the M5 streaming replica.
REPL_USER=replicator
REPL_PASSWORD=replicator

# --- App --------------------------------------------------------------------
APP_PORT=3000
# Writes go here (through PgBouncer -> primary).
DATABASE_URL=postgres://app:app@pgbouncer:6432/app
# Reads go here when the m2 profile is active. Empty in the base = read primary.
DATABASE_REPLICA_URL=
# Set SLOW=1 to artificially delay responses (drives M2/M18 fault demos).
SLOW=0
SLOW_MS=750
# --- Queue (M12) -------------------------------------------------------------
AMQP_URL=amqp://app:app@rabbitmq:5672
RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=app

# --- Redis (M10/M17/M7) ------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Object store (M9) -----------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Observability traces/logs (M19) -----------------------------------------
# Where the app/worker ship OTLP telemetry. Points at the collector, which runs
# only under the m19-observability profile; other profiles export to a dead
# address and drop the data harmlessly. Override to send elsewhere.
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# --- Published host ports ---------------------------------------------------
GATEWAY_HTTP_PORT=8080
EDGE_HTTP_PORT=8082
HAPROXY_STATS_PORT=8404
RABBITMQ_UI_PORT=15672
GRAFANA_PORT=3001
KAFKA_UI_PORT=8081
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9101
# M1 DNS: host port that maps to the caching resolver's port 53 (dig from host
# with `dig -p 5354 @127.0.0.1 www.shop.internal`).
DNS_RESOLVER_PORT=5354
