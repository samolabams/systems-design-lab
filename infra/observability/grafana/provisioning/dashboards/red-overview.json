{
  "annotations": { "list": [] },
  "editable": true,
  "title": "RED — gateway → app → DB",
  "uid": "red-overview",
  "tags": ["systems-design-lab"],
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Rate (requests/sec by status)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errors (5xx rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Duration (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p50",
          "exemplar": true
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p95",
          "exemplar": true
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "p99",
          "exemplar": true
        }
      ]
    },
    {
      "type": "row",
      "title": "SLO & error budget (availability)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "type": "stat",
      "title": "Success ratio (SLI, 30m)",
      "description": "Share of non-5xx responses. The SLI the 99.9% SLO is measured against.",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status!~\"5..\"}[30m])) / sum(rate(http_requests_total[30m]))",
          "legendFormat": "success ratio"
        }
      ]
    },
    {
      "type": "gauge",
      "title": "Error budget remaining (30d, 99.9%)",
      "description": "Fraction of the monthly error budget (1 - SLO = 0.1%) still unspent. Drains as 5xx accrue.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "clamp_min(1 - ( (sum(rate(http_requests_total{status=~\"5..\"}[30m])) / sum(rate(http_requests_total[30m]))) / 0.001 ), 0)",
          "legendFormat": "budget remaining"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Burn rate (× budget, 1h vs 99.9%)",
      "description": "How many times faster than sustainable the budget is being spent. >1 means the 30d budget will be exhausted early; multi-window burn-rate alerts page on sustained spikes.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 17 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "( sum(rate(http_requests_total{status=~\"5..\"}[1h])) / sum(rate(http_requests_total[1h])) ) / 0.001",
          "legendFormat": "burn rate"
        }
      ]
    }
  ]
}
